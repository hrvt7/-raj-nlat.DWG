# ─── TakeoffPro Environment Configuration ────────────────────────────────────
# Copy this file to .env and fill in the values.
#
# REQUIRED for remote features (auth, cloud sync, subscription):
#   VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY
#
# Without these, the app runs in offline/localStorage-only mode.
# The console will show a clear warning if they are missing.

# ─── Client-side (Vite) ──────────────────────────────────────────────────────
# Supabase project URL and anon key — required for auth, quotes, settings sync
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...your-anon-key

# Backend API URL for serverless functions (Vercel deployment URL)
# Required only for AI features (meta-vision, AI takeoff)
VITE_API_URL=https://your-deployment.vercel.app

# ─── Server-side only (Vercel Environment Variables) ─────────────────────────
# NEVER prefix these with VITE_ — they must stay server-side only.
#
# Supabase credentials for Python API auth (require_auth in security_helpers.py)
# These MUST be set in Vercel → Settings → Environment Variables for Production.
# Without these, ALL authenticated API endpoints return 401 (code: config_missing).
# The values are the same as VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY above.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-key
#
# OpenAI API key — used by /api/meta-vision and /api/ai serverless functions
# OPENAI_API_KEY=sk-...
#
# CORS origin restriction — set to your production domain in production
# ALLOWED_ORIGIN=https://your-app.vercel.app
#
# Stripe keys — used by /api/create-checkout and /api/stripe-webhook
# STRIPE_SECRET_KEY=sk_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...
#
# Supabase service role key — used by /api/notify-quote-accepted (server-side only)
# SUPABASE_SERVICE_ROLE_KEY=eyJ...service-role-key
#
# Email notifications — used by /api/notify-quote-accepted
# Get a free key at https://resend.com (100 emails/day free tier)
# Without this, quote acceptance still works but the contractor gets no email.
# RESEND_API_KEY=re_...
# NOTIFY_FROM_EMAIL=no-reply@yourdomain.com
